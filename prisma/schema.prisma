// Mona Niko Art Gallery - Prisma Schema
// SQLite for local development

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ─── ENUMS (SQLite doesn't support enums natively, using String with comments) ───

// Role: ADMIN | CUSTOMER
// ArtworkCategory: PAINTING | SCULPTURE_3D | MIXED_MEDIA | LIMITED_EDITION
// ArtworkStatus: AVAILABLE | SOLD | ON_EXHIBITION | COMMISSIONED
// ProductType: ORIGINAL | PRINT | MERCH_TSHIRT | MERCH_SWEATSHIRT | MERCH_LEGGINGS | MERCH_PHONE_CASE | MERCH_CUSHION | MERCH_LAPTOP_CASE | MERCH_SUITCASE | MERCH_TIE | DESIGNERS_COLLECTION | WORKSHOP
// WorkshopLevel: BEGINNER | INTERMEDIATE | ADVANCED | ALL_LEVELS
// OrderStatus: PENDING | CONFIRMED | PROCESSING | SHIPPED | DELIVERED | CANCELLED
// PaymentStatus: PENDING | PAID | REFUNDED
// JournalStatus: DRAFT | SCHEDULED | PUBLISHED
// InquiryType: ARTWORK | COMMISSION | PRIVATE_VIEWING | GENERAL | PRESS
// InquiryStatus: NEW | CONTACTED | IN_PROGRESS | CLOSED
// DiscountType: PERCENTAGE | FIXED
// CampaignStatus: DRAFT | SCHEDULED | ACTIVE | COMPLETED | PAUSED

// ─── MODELS ─────────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  firstName String
  lastName  String
  role      String   @default("CUSTOMER") // ADMIN | CUSTOMER
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders       Order[]
  wishlistItems WishlistItem[]
}

model Artwork {
  id             String   @id @default(cuid())
  title          String
  slug           String   @unique
  description    String?
  images         String   @default("[]") // JSON array of image URLs
  category       String   // PAINTING | SCULPTURE_3D | MIXED_MEDIA | LIMITED_EDITION
  medium         String?
  dimensions     String?  // JSON: { width, height, depth, unit }
  year           Int?
  status         String   @default("AVAILABLE") // AVAILABLE | SOLD | ON_EXHIBITION | COMMISSIONED
  price          Float?
  priceOnInquiry Boolean  @default(false)
  collectionId   String?
  tags           String   @default("[]") // JSON array of tags
  featured       Boolean  @default(false)
  framing        String?
  certificate    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  collection    Collection?    @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  products      Product[]
  inquiries     Inquiry[]
  wishlistItems WishlistItem[]

  @@index([collectionId])
  @@index([category])
  @@index([status])
  @@index([featured])
}

model Collection {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?
  coverImage  String?
  featured    Boolean  @default(false)
  year        Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  artworks Artwork[]
}

model Product {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  description String?
  images    String   @default("[]") // JSON array of image URLs
  type      String   // ORIGINAL | PRINT | MERCH_TSHIRT | MERCH_SWEATSHIRT | MERCH_LEGGINGS | MERCH_PHONE_CASE | MERCH_CUSHION | MERCH_LAPTOP_CASE | MERCH_SUITCASE | MERCH_TIE | DESIGNERS_COLLECTION | WORKSHOP
  basePrice Float
  artworkId String?
  featured  Boolean  @default(false)
  tags      String   @default("[]") // JSON array of tags
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  artwork       Artwork?         @relation(fields: [artworkId], references: [id], onDelete: SetNull)
  variants      ProductVariant[]
  wishlistItems WishlistItem[]

  @@index([artworkId])
  @@index([type])
  @@index([featured])
}

model ProductVariant {
  id         String   @id @default(cuid())
  productId  String
  name       String
  price      Float
  dimensions String?
  sku        String?  @unique
  stock      Int      @default(0)
  createdAt  DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Workshop {
  id              String   @id @default(cuid())
  title           String
  slug            String   @unique
  description     String?
  longDescription String?
  images          String   @default("[]") // JSON array of image URLs
  date            DateTime
  endDate         DateTime?
  time            String?
  duration        String?
  location        String?
  isOnline        Boolean  @default(false)
  price           Float
  capacity        Int
  spotsLeft       Int
  instructor      String?
  level           String   @default("ALL_LEVELS") // BEGINNER | INTERMEDIATE | ADVANCED | ALL_LEVELS
  materials       String   @default("[]") // JSON array of required materials
  featured        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([date])
  @@index([featured])
}

model Order {
  id              String   @id @default(cuid())
  orderNumber     String   @unique
  userId          String?
  customerEmail   String
  customerName    String
  customerPhone   String?
  shippingAddress String?  // JSON: { line1, line2, city, state, zip, country }
  subtotal        Float
  tax             Float    @default(0)
  shipping        Float    @default(0)
  total           Float
  status          String   @default("PENDING") // PENDING | CONFIRMED | PROCESSING | SHIPPED | DELIVERED | CANCELLED
  paymentStatus   String   @default("PENDING") // PENDING | PAID | REFUNDED
  paymentIntentId String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user  User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  items OrderItem[]

  @@index([userId])
  @@index([orderNumber])
  @@index([status])
  @@index([paymentStatus])
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  productId String?
  variantId String?
  title     String
  image     String?
  price     Float
  quantity  Int    @default(1)

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model JournalPost {
  id             String    @id @default(cuid())
  title          String
  slug           String    @unique
  excerpt        String?
  content        String?
  coverImage     String?
  author         String?
  category       String?
  tags           String    @default("[]") // JSON array of tags
  status         String    @default("DRAFT") // DRAFT | SCHEDULED | PUBLISHED
  publishedAt    DateTime?
  scheduledAt    DateTime?
  seoTitle       String?
  seoDescription String?
  seoImage       String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status])
  @@index([publishedAt])
}

model Inquiry {
  id        String   @id @default(cuid())
  type      String   // ARTWORK | COMMISSION | PRIVATE_VIEWING | GENERAL | PRESS
  name      String
  email     String
  phone     String?
  message   String
  artworkId String?
  budget    String?
  status    String   @default("NEW") // NEW | CONTACTED | IN_PROGRESS | CLOSED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  artwork Artwork? @relation(fields: [artworkId], references: [id], onDelete: SetNull)

  @@index([artworkId])
  @@index([type])
  @@index([status])
}

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  firstName String?
  lastName  String?
  segments  String   @default("[]") // JSON array of segment tags
  source    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Testimonial {
  id       String   @id @default(cuid())
  name     String
  role     String?
  text     String
  image    String?
  rating   Int?
  featured Boolean  @default(false)
  createdAt DateTime @default(now())
}

model PressItem {
  id          String   @id @default(cuid())
  title       String
  publication String?
  date        DateTime?
  url         String?
  excerpt     String?
  image       String?
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Campaign {
  id             String    @id @default(cuid())
  title          String
  description    String?
  objective      String?
  channels       String    @default("[]") // JSON array of channel names
  status         String    @default("DRAFT") // DRAFT | SCHEDULED | ACTIVE | COMPLETED | PAUSED
  startDate      DateTime?
  endDate        DateTime?
  targetSegments String    @default("[]") // JSON array of target segment tags
  metrics        String    @default("{}") // JSON object of metrics
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status])
}

model PromoCode {
  id            String    @id @default(cuid())
  code          String    @unique
  description   String?
  discountType  String    // PERCENTAGE | FIXED
  discountValue Float
  minPurchase   Float?
  maxUses       Int?
  usedCount     Int       @default(0)
  validFrom     DateTime?
  validUntil    DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())

  @@index([code])
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  artworkId String?
  productId String?
  createdAt DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  artwork Artwork? @relation(fields: [artworkId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, artworkId])
  @@unique([userId, productId])
  @@index([userId])
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   // JSON string for complex values
  updatedAt DateTime @updatedAt

  @@index([key])
}

model ScheduledContent {
  id          String    @id @default(cuid())
  title       String
  type        String    // journal_post | campaign_post | email_blast | social_post
  scheduledAt DateTime
  status      String    @default("scheduled") // scheduled | published | failed | cancelled
  channel     String?   // email | instagram | facebook | pinterest | x | blog
  contentRef  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([scheduledAt])
  @@index([status])
  @@index([type])
}

model ActivityLog {
  id         String   @id @default(cuid())
  entityType String   // artwork | collection | order | etc.
  entityId   String
  action     String   // create | update | delete
  details    String?  // JSON string with change details
  userId     String?
  createdAt  DateTime @default(now())

  @@index([entityType])
  @@index([createdAt])
}

// ─── ACCOUNTING ──────────────────────────────────────────────────────────────

model Expense {
  id          String   @id @default(cuid())
  date        DateTime
  vendor      String
  category    String   // RENT | SUPPLIES | MARKETING | SOFTWARE | SHIPPING | UTILITIES | SALARIES | INSURANCE | EQUIPMENT | OTHER
  description String?
  amount      Float
  receiptUrl  String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
  @@index([category])
}

model Invoice {
  id            String    @id @default(cuid())
  invoiceNumber String    @unique
  orderId       String?
  clientName    String
  clientEmail   String
  clientAddress String?   // JSON: { line1, line2, city, state, zip, country }
  lineItems     String    @default("[]") // JSON: [{ description, qty, unitPrice, amount }]
  subtotal      Float
  taxRate       Float     @default(0)
  tax           Float     @default(0)
  total         Float
  status        String    @default("DRAFT") // DRAFT | SENT | PAID | OVERDUE | CANCELLED
  issuedAt      DateTime  @default(now())
  dueAt         DateTime?
  paidAt        DateTime?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status])
  @@index([issuedAt])
  @@index([clientEmail])
}

// ─── EMAIL MARKETING ─────────────────────────────────────────────────────────

model EmailTemplate {
  id          String   @id @default(cuid())
  name        String
  subject     String
  html        String
  previewText String?
  category    String   @default("newsletter") // newsletter | collection | workshop | promo | custom
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  blasts EmailBlast[]

  @@index([category])
}

model EmailBlast {
  id             String    @id @default(cuid())
  subject        String
  html           String
  previewText    String?
  segment        String    // all | newsletter | collector | print_buyer | workshop_attendee | vip | press
  status         String    @default("DRAFT") // DRAFT | SENDING | SENT | FAILED
  recipientCount Int       @default(0)
  sentCount      Int       @default(0)
  failedCount    Int       @default(0)
  sentAt         DateTime?
  templateId     String?
  campaignId     String?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  template EmailTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([sentAt])
  @@index([segment])
}

// ─── COMMISSIONS ──────────────────────────────────────────────────────────────

model Commission {
  id                 String    @id @default(cuid())
  inquiryId          String?   // soft ref to Inquiry.id
  clientName         String
  clientEmail        String
  clientPhone        String?
  stage              String    @default("CONSULTATION") // CONSULTATION | CONCEPT | DEPOSIT_PENDING | DEPOSIT_PAID | IN_PROGRESS | REVIEW | COMPLETED | CANCELLED
  artworkDescription String?
  medium             String?
  dimensions         String?
  colorNotes         String?
  deadline           DateTime?
  depositAmount      Float?
  totalAmount        Float?
  depositPaidAt      DateTime?
  completedAt        DateTime?
  references         String    @default("[]") // JSON: [{ url, note }]
  artworkId          String?   // soft ref to Artwork.id once created
  notes              String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([stage])
  @@index([clientEmail])
}

// ─── CERTIFICATES ─────────────────────────────────────────────────────────────

model Certificate {
  id                String   @id @default(cuid())
  certificateNumber String   @unique
  artworkTitle      String
  artworkDescription String?
  medium            String?
  dimensions        String?
  year              Int?
  edition           String?
  artistName        String   @default("Mona Niko")
  recipientName     String
  orderId           String?  // soft ref to Order.id
  artworkId         String?  // soft ref to Artwork.id
  notes             String?
  issuedAt          DateTime @default(now())
  createdAt         DateTime @default(now())

  @@index([orderId])
  @@index([artworkId])
}

// ─── COLLECTOR CLUB ───────────────────────────────────────────────────────────

model CollectorMembership {
  id        String    @id @default(cuid())
  userId    String?   // soft ref to User.id
  name      String
  email     String    @unique
  tier      String    @default("SILVER") // SILVER | GOLD | PLATINUM
  status    String    @default("ACTIVE") // ACTIVE | SUSPENDED | CANCELLED
  joinedAt  DateTime  @default(now())
  expiresAt DateTime?
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([tier])
  @@index([status])
  @@index([email])
}

// ─── AUCTIONS ─────────────────────────────────────────────────────────────────

model Auction {
  id           String      @id @default(cuid())
  artworkId    String?     // soft ref to Artwork.id
  artworkTitle String
  artworkImage String?
  slug         String      @unique
  startingBid  Float
  reservePrice Float?
  currentBid   Float?
  winnerEmail  String?
  winnerName   String?
  winnerBidId  String?     // soft ref to winning AuctionBid.id
  status       String      @default("DRAFT") // DRAFT | LIVE | ENDED | CANCELLED
  startAt      DateTime
  endAt        DateTime
  description  String?
  notes        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  bids AuctionBid[]

  @@index([status])
  @@index([endAt])
  @@index([slug])
}

model AuctionBid {
  id          String   @id @default(cuid())
  auctionId   String
  bidderName  String
  bidderEmail String
  amount      Float
  isWinning   Boolean  @default(false)
  createdAt   DateTime @default(now())

  auction Auction @relation(fields: [auctionId], references: [id], onDelete: Cascade)

  @@index([auctionId])
  @@index([auctionId, amount])
}
